# Cats Maker Bot Environment Variables
# Copy this file to .env and fill in your values

# Bot credentials for Wikipedia API
WIKIPEDIA_BOT_USERNAME=your_bot_username
WIKIPEDIA_BOT_PASSWORD=your_bot_password

# Project path (optional - defaults to current directory if not set)
PROJECT_PATH=/data/project/himo

# SQL database access (for quarry.wmcloud.org replica)
# Only needed if running in production environment
# SQL_HOST=
# SQL_USER=
# SQL_PASSWORD=
# SQL_DATABASE=

# Logging configuration
CATS_MAKER_LOG_FILE=~/BOTS_LOGS/cats_maker_new.log

# Optional: Path to ArWikiCats (for development)
# ARWIKICATS_PATH=/path/to/ArWikiCats
